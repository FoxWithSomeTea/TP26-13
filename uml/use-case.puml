@startuml
skinparam packageStyle rectangle
skinparam actorStyle awesome
skinparam usecaseFontSize 10
skinparam defaultFontSize 10
skinparam packageMargin 10

rectangle "Funkce studenta" {
  (Prohlížet zadání)
  (Stáhnout zadání PDF)
  (Nahrát soubory)
  (Smazat soubory)
  (Napsat poznámku)
  (Odevzdat práci)
  (Zobrazit známku)
}

rectangle "Funkce učitele" {
  (Prohlížet studenty)
  (Detail studenta)
  (Nahrát zadání PDF)
  (Stáhnout soubory)
  (Ohodnotit práci)
  (Napsat hodnocení)
}

rectangle "Funkce admina" {
  (Spravovat uživatele)
  (Spravovat třídy)
  (Importovat studenty)
  (Zobrazit statistiky)
}

rectangle "Společné" {
  (Přihlásit se)
  (Změnit heslo)
  (Poslat zprávu)
  (Číst zprávy)
}

(Spravovat uživatele) <.. (Spravovat třídy) : <<extend>>
(Spravovat uživatele) <.. (Importovat studenty) : <<extend>>
@enduml
