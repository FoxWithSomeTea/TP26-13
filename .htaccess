# Hide PHP errors from the browser (log them instead)
php_flag display_errors off
php_value error_reporting E_ALL

# Prevent directory listing
Options -Indexes

# Block access to sensitive files via HTTP
<FilesMatch "\.(sql|md)$">
    Require all denied
</FilesMatch>
<FilesMatch "^(db\.php)$">
    Require all denied
</FilesMatch>

# Security headers
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
</IfModule>
